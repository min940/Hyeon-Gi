<?xml version="1.0" encoding="utf-8"?>
<!--
  이 파일을 같은 폴더에 secrets.xml 이름으로 복사한 뒤 값을 채우세요.
  (secrets.xml 은 .gitignore 로 커밋되지 않습니다 — 웹앱의 .env 와 같은 역할)

  값은 웹앱 .env 의 VITE_KID_EMAIL / VITE_AUTH_SUFFIX 와 반드시 동일해야 합니다.
  백그라운드 서비스가 이 계정으로 Firebase 에 로그인해 위치를 기록합니다.
-->
<resources>
    <string name="kid_email">kid@kids-dashboard.app</string>
    <string name="auth_suffix">Fam2026!</string>
</resources>
