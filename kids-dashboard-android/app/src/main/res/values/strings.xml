<resources>
    <string name="app_name">오늘의 하루</string>

    <!-- ⬇️ 배포한 사이트 주소 (Firebase Hosting) -->
    <string name="site_url">https://hyeong-gi-schedule.web.app/</string>

    <!--
      접속을 허용할 도메인 목록.
      site_url 의 호스트와 Firebase 관련 도메인이 포함되어 있어야 합니다.
      (web.app / firebaseapp.com 은 호스팅, googleapis.com 은 Firestore·로그인,
       gstatic.com 은 인터넷 연결 확인용)
      이 목록에 없는 사이트는 앱에서 열리지 않습니다.
    -->
    <string-array name="allowed_hosts">
        <item>web.app</item>
        <item>firebaseapp.com</item>
        <item>googleapis.com</item>
        <item>gstatic.com</item>
    </string-array>
</resources>
