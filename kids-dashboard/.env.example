# Firebase 웹 앱 config 값 (Firebase 콘솔 → 프로젝트 설정 → 웹 앱에서 발급)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# 로그인 계정 (Firebase Authentication → Users 에 동일한 이메일로 계정 생성)
VITE_KID_EMAIL=kid@kids-dashboard.app
VITE_MOM_EMAIL=mom@kids-dashboard.app

# PIN 뒤에 자동으로 붙는 비밀번호 접미사
# 예) 접미사가 Fam2026! 이면 자녀 실제 비밀번호 = 1234Fam2026!
VITE_AUTH_SUFFIX=Fam2026!
