rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isMom() {
      return isSignedIn()
             && request.auth.token.email == "mom@kids-dashboard.app";
    }
    function isKid() {
      return isSignedIn()
             && request.auth.token.email == "kid@kids-dashboard.app";
    }

    // 위치: 로그인 사용자 읽기, 자녀/엄마 쓰기
    // (자녀 기기가 자기 위치를 기록해야 하므로 자녀 쓰기 허용)
    match /locations/{doc} {
      allow read: if isSignedIn();
      allow write: if isKid() || isMom();
    }

    // 위치 수집 설정: 로그인 사용자 읽기, 엄마만 쓰기
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isMom();
    }

    // 명령(정밀 위치 요청): 엄마가 요청 생성, 자녀가 완료 표시
    match /commands/{doc} {
      allow read: if isSignedIn();
      allow write: if isKid() || isMom();
    }

    // 완료 기록(일정·과제 완료 체크): 로그인 읽기, 자녀/엄마 쓰기
    // (자녀가 완료를 체크하면 기록해야 하므로 자녀 쓰기 허용)
    match /completions/{doc} {
      allow read: if isSignedIn();
      allow write: if isKid() || isMom();
    }

    // 이동 경로 이력: 로그인 읽기, 자녀/엄마 쓰기 (자녀 기기가 좌표를 기록)
    match /locationHistory/{doc} {
      allow read: if isSignedIn();
      allow write: if isKid() || isMom();
    }

    // 그 외(일정·용돈·요일템플릿 등): 읽기는 로그인, 쓰기는 엄마만
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isMom();
    }
  }
}
